# 이 파일을 .env.local 로 복사한 뒤 각 키를 채우세요.

# Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=여기에_키를_붙여넣기

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...(anon public 키)
# service_role 키는 비밀! 서버 전용, 절대 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...(service_role 키)

# ── (선택) 새 문의 이메일 알림 — https://resend.com ──────────────────────────
# 없어도 동작함(문의는 /admin 에서 열람 가능). 키가 있으면 새 문의 시 관리자에게 메일 발송.
# MAIL_FROM 의 도메인(taif.kr)은 Resend에서 도메인 인증을 마쳐야 발송됩니다.
RESEND_API_KEY=
MAIL_FROM=mypet 문의 <noreply@taif.kr>

# ── 관리자 페이지(/admin) 비밀번호 — 문의/환불 열람 ─────────────────────────
# 설정 안 하면 /admin 로그인 불가. Vercel 환경변수에도 동일하게 넣을 것.
ADMIN_PASSWORD=원하는_비밀번호

# ── (선택) PG 결제 — PortOne ────────────────────────────────────────────────
# 키가 없으면 결제는 샌드박스(테스트) 모드로 동작. 실결제 시 설정.
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=
